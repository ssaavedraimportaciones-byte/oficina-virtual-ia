# ═══════════════════════════════════════════════════════════
# SafeCheck AI — Variables de Entorno (Staging/Producción)
# ═══════════════════════════════════════════════════════════
# Copiar a .env.local (local) o agregar en Vercel → Settings → Environment Variables
# NUNCA commitear este archivo con valores reales.
# Secrets mínimo 32 caracteres. Sin fallbacks: app falla al iniciar si faltan.
#
# Generar secrets:
#   openssl rand -base64 64   → para JWT_SECRET, JWT_REFRESH_SECRET, QR_SECRET
# ═══════════════════════════════════════════════════════════

# ── [REQUERIDO] Base de datos — Neon PostgreSQL ──────────
# Neon → Project → Connection String → Pooled connection
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/safecheck?sslmode=require"

# ── [REQUERIDO] Auth secrets ─────────────────────────────
# Cada uno debe ser distinto e independiente
JWT_SECRET=""
JWT_REFRESH_SECRET=""
QR_SECRET=""

# ── [REQUERIDO] App URL ───────────────────────────────────
# Vercel → Project → Domains (sin trailing slash)
NEXT_PUBLIC_APP_URL="https://safecheck-staging.vercel.app"
NODE_ENV="production"

# ── [REQUERIDO] Vercel Blob — Storage ────────────────────
# Vercel → Project → Storage → Create Store → Blob → .env.local
STORAGE_PROVIDER="vercel_blob"
BLOB_READ_WRITE_TOKEN=""
# URL base del Blob store (aparece en Vercel al crear el store)
BLOB_BASE_URL="https://XXXX.public.blob.vercel-storage.com"

# ── [RECOMENDADO] Email — Resend ──────────────────────────
# resend.com → API Keys → Create Key
EMAIL_PROVIDER="resend"
EMAIL_FROM="SafeCheck AI <no-reply@tudominio.com>"
RESEND_API_KEY=""
# Alternativa SMTP:
# EMAIL_PROVIDER="smtp"
# SMTP_HOST=""
# SMTP_PORT="587"
# SMTP_USER=""
# SMTP_PASS=""

# ── [RECOMENDADO] Jobs — Inngest ──────────────────────────
# inngest.com → App → Event Keys + Signing Keys
# memory = jobs en proceso (staging simple); inngest = producción resiliente
JOB_PROVIDER="inngest"
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""
# Para staging sin Inngest:
# JOB_PROVIDER="memory"

# ── [RECOMENDADO] Redis — Upstash ────────────────────────
# upstash.com → Database → REST API
RATE_LIMIT_PROVIDER="redis"
CACHE_PROVIDER="redis"
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
# Para staging sin Redis:
# RATE_LIMIT_PROVIDER="memory"
# CACHE_PROVIDER="memory"

# ── [RECOMENDADO] OCR — Azure Document Intelligence ──────
# portal.azure.com → Cognitive Services → Document Intelligence → Keys and Endpoint
# Dejar vacío para usar mock OCR (staging demo sin Azure)
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=""
AZURE_DOCUMENT_INTELLIGENCE_KEY=""

# ── [RECOMENDADO] IA — Anthropic ─────────────────────────
# console.anthropic.com → API Keys
ANTHROPIC_API_KEY=""

# ── [RECOMENDADO] Monitoreo — Sentry ─────────────────────
# sentry.io → Project → Settings → DSN
# Dejar vacío para deshabilitar (staging sin costo)
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
# Para source maps en producción:
# SENTRY_AUTH_TOKEN=""
# SENTRY_ORG=""
# SENTRY_PROJECT=""

# ── [OPCIONAL] Alertas — Slack ────────────────────────────
# api.slack.com → Apps → Incoming Webhooks
# Recibe alertas cuando un job OCR/PDF falla permanentemente (DLQ)
SLACK_ALERT_WEBHOOK=""

# ── [OPCIONAL] Versión ────────────────────────────────────
NEXT_PUBLIC_APP_VERSION="1.0.0"

# ═══════════════════════════════════════════════════════════
# PASOS POST-DEPLOY (ejecutar una sola vez):
#
#   1. Migrar schema:
#      npx prisma migrate deploy
#      (o: npm run db:migrate:deploy)
#
#   2. Aplicar RLS (append-only audit log):
#      psql $DATABASE_URL -f prisma/rls-audit-log.sql
#      (o: npm run db:rls)
#
#   3. Seed datos piloto:
#      npx prisma db seed
#      (o: npm run db:seed)
#
#   4. Smoke tests:
#      BASE_URL=https://safecheck-staging.vercel.app npm run smoke
#
# RIESGOS RESIDUALES STAGING:
#   - JOB_PROVIDER=memory: sin retry automático → usar inngest en piloto real
#   - Vercel Blob free tier: acceso público por URL → proxy JWT cubre esto
#   - RLS debe aplicarse manualmente después de cada migrate deploy
# ═══════════════════════════════════════════════════════════
