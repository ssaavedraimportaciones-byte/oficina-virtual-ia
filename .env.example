# Database — PostgreSQL
DATABASE_URL="postgresql://safecheck:password@localhost:5432/safecheck_db"

# JWT — mínimo 64 caracteres (openssl rand -base64 64)
JWT_SECRET=
JWT_REFRESH_SECRET=

# App
NEXT_PUBLIC_URL=https://safecheck.vercel.app
NEXT_PUBLIC_APP_NAME=SafeCheck AI
NODE_ENV=development

# ─── OCR: Azure Document Intelligence ───────────────────────────────────────
# Crear recurso en portal.azure.com > Document Intelligence
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://<tu-recurso>.cognitiveservices.azure.com
AZURE_DOCUMENT_INTELLIGENCE_KEY=

# ─── Almacenamiento de archivos originales ───────────────────────────────────
# Opción A: sistema de archivos local (desarrollo)
UPLOAD_DIR=./uploads
UPLOAD_URL_PREFIX=/uploads

# Opción B: Azure Blob Storage (producción)
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
# AZURE_STORAGE_CONTAINER=safecheck-docs
