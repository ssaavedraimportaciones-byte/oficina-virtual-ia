# Database — PostgreSQL
DATABASE_URL="postgresql://safecheck:password@localhost:5432/safecheck_db"

# JWT — mínimo 64 caracteres (openssl rand -base64 64)
JWT_SECRET=
JWT_REFRESH_SECRET=

# App
NEXT_PUBLIC_URL=https://safecheck.vercel.app
NEXT_PUBLIC_APP_NAME=SafeCheck AI
NODE_ENV=development

# ─── IA: Anthropic Claude ────────────────────────────────────────────────────
# Obtener en console.anthropic.com
ANTHROPIC_API_KEY=

# ─── OCR: Azure Document Intelligence ───────────────────────────────────────
# Crear recurso en portal.azure.com > Document Intelligence
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://<tu-recurso>.cognitiveservices.azure.com
AZURE_DOCUMENT_INTELLIGENCE_KEY=

# ─── Almacenamiento de archivos originales ───────────────────────────────────
# Opción A: sistema de archivos local (desarrollo)
UPLOAD_DIR=./uploads
UPLOAD_URL_PREFIX=/uploads

# Opción B: Azure Blob Storage (producción)
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
# AZURE_STORAGE_CONTAINER=safecheck-docs

# ─── Notificaciones: Email (SMTP) ────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=SafeCheck AI <no-reply@safecheck.ai>

# Opción alternativa: Resend (sobreescribe SMTP si está definido)
# RESEND_API_KEY=re_...

# ─── Notificaciones: WhatsApp Business (Meta Cloud API) ─────────────────────
# Obtener en developers.facebook.com > WhatsApp > API Setup
# Requiere plantillas de mensaje aprobadas en Meta Business Manager
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# ─── App pública (para links en emails y QR) ─────────────────────────────────
NEXT_PUBLIC_APP_URL=https://safecheck.ai
