# ═══════════════════════════════════════════════════════════
# SafeCheck AI — Staging Environment Variables
# ═══════════════════════════════════════════════════════════
# Copy this file to .env.staging and fill in real values.
# NEVER commit .env.staging to the repository.
# All secrets must be at least 32 characters.
# No fallbacks: if a required variable is missing, the app fails on startup.
# ═══════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/safecheck_staging?sslmode=require"

# ── Auth secrets (min 32 chars each, generate with: openssl rand -base64 48) ─
# IMPORTANTE: Cada variable debe tener un valor distinto e independiente.
# Generar con: openssl rand -base64 64
JWT_SECRET=""
JWT_REFRESH_SECRET=""
QR_SECRET=""

# ── Azure Document Intelligence (OCR) ────────────────────
# Leave blank to use the mock OCR (safe for staging demo)
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=""
AZURE_DOCUMENT_INTELLIGENCE_KEY=""

# ── File Storage ──────────────────────────────────────────
# Opción A: Vercel Blob (recomendado staging — zero-config en Vercel)
# Obtener token: Vercel → Storage → Blob → Create Store → .env.local
STORAGE_PROVIDER="vercel_blob"
BLOB_READ_WRITE_TOKEN=""

# Opción B: Local (solo desarrollo — no persiste en Vercel serverless)
# STORAGE_PROVIDER="local"
# UPLOAD_DIR="/var/safecheck/uploads"
# UPLOAD_URL_PREFIX="/uploads"

# Opción C: Azure Blob (pilot/producción)
# STORAGE_PROVIDER="azure"
# AZURE_STORAGE_CONNECTION_STRING=""
# AZURE_STORAGE_CONTAINER="safecheck-docs"

# ── App ────────────────────────────────────────────────────
APP_URL="https://safecheck-staging.yourdomain.com"
NODE_ENV="production"
NEXTAUTH_URL="${APP_URL}"

# ── Email (leave blank to disable email notifications in staging) ──
EMAIL_PROVIDER=""
EMAIL_FROM="SafeCheck AI <no-reply@yourdomain.com>"
# SMTP_HOST=""
# SMTP_PORT="587"
# SMTP_USER=""
# SMTP_PASS=""

# ── Jobs async (OCR + PDF) ────────────────────────────────
# memory: usa next/server after() — jobs persistidos en DB, worker en proceso
# inngest: usa Inngest cloud — retries, observabilidad, recomendado producción
JOB_PROVIDER="memory"
# Si JOB_PROVIDER=inngest, agregar:
# INNGEST_EVENT_KEY=""      # Inngest → App → Event Keys → Create
# INNGEST_SIGNING_KEY=""    # Inngest → App → Signing Keys

# ── Rate limiting ──────────────────────────────────────────
# In-memory por defecto; Redis para multi-instancia
# REDIS_URL=""

# ═══════════════════════════════════════════════════════════
# STAGING RESIDUAL RISKS (document before pilot):
#   1. JOB_PROVIDER=memory: jobs no tienen retry automático.
#      Cambiar a inngest antes de producción.
#   2. Signature images stored as base64 in DB (Signature.signatureImageUrl).
#      Move to blob storage before production.
#   3. Local file storage is single-instance only.
#      Switch to Azure Blob / S3 before scaling.
#   4. RLS on AuditLog must be applied after first migration:
#      psql $DATABASE_URL -f prisma/rls-audit-log.sql
# ═══════════════════════════════════════════════════════════
