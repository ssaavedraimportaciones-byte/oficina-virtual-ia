generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════════
// ENUMS — especificados por el sistema
// ═══════════════════════════════════════════════════════════════

enum UserRole {
  WORKER
  SUPERVISOR
  PREVENTIONIST
  CONTRACT_ADMIN
  MANAGER
  AUDITOR
  SYSTEM_ADMIN
}

enum CompanyType {
  MANDANTE
  CONTRATISTA
  SUBCONTRATISTA
}

enum DocumentType {
  SAFETY_TALK
  DET
  ART
  AST
  WORK_PERMIT
  LOTO
  HEIGHT_WORK
  CONFINED_SPACE
  LIFTING_PLAN
  EQUIPMENT_CHECKLIST
  OTHER
}

enum DocumentStatus {
  DRAFT
  SCANNED
  AI_REVIEW
  OBSERVED
  PENDING_SIGNATURE
  PENDING_APPROVAL
  APPROVED
  REJECTED
  CLOSED
  ARCHIVED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  OBSERVED
}

// ═══════════════════════════════════════════════════════════════
// ENUMS adicionales — necesarios para integridad (no en el spec)
// ═══════════════════════════════════════════════════════════════

enum Criticality {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum SignatureMethod {
  DIGITAL      // firma electrónica en pantalla
  HANDWRITTEN  // imagen de firma escaneada
  BIOMETRIC    // huella dactilar / facial
}

enum NotificationChannel {
  EMAIL
  SMS
  PUSH
  IN_APP
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  READ
}

enum JobType {
  OCR
  PDF
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

// ═══════════════════════════════════════════════════════════════
// COMPANY
// ═══════════════════════════════════════════════════════════════

model Company {
  id        String      @id @default(cuid())
  name      String
  rut       String      @unique
  type      CompanyType
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  users     User[]
  workers   Worker[]
  documents Document[]

  @@map("companies")
}

// ═══════════════════════════════════════════════════════════════
// USER
// passwordHash no se expone por defecto — usar select explícito
// ═══════════════════════════════════════════════════════════════

model User {
  id           String   @id @default(cuid())
  name         String
  rut          String   @unique
  email        String   @unique
  phone        String?
  role         UserRole @default(WORKER)
  companyId    String
  isActive     Boolean  @default(true)
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company        Company        @relation(fields: [companyId], references: [id])
  supervisedDocs Document[]     @relation("DocumentSupervisor")
  preventionDocs Document[]     @relation("DocumentPreventionist")
  createdDocs    Document[]     @relation("DocumentCreatedBy")
  signatures     Signature[]
  approvals      Approval[]
  auditLogs      AuditLog[]
  notifications  Notification[]
  refreshTokens  RefreshToken[]
  jobs           Job[]

  @@index([companyId])
  @@index([role])
  @@map("users")
}

// Tokens de refresh separados — permiten revocación individual
model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// ═══════════════════════════════════════════════════════════════
// WORKER
// Trabajador de campo — puede o no tener cuenta User
// ═══════════════════════════════════════════════════════════════

model Worker {
  id             String   @id @default(cuid())
  name           String
  rut            String   @unique
  companyId      String
  position       String
  certifications String[] // PostgreSQL array: ["Altura", "LOTO"]
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  company        Company  @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@map("workers")
}

// ═══════════════════════════════════════════════════════════════
// DOCUMENT
// folio: generado en aplicación — ver advertencia #1
// qrCode: hash final del documento timbrado
// aiResult / validationResult: Json flexible hasta estabilizar schema
// ═══════════════════════════════════════════════════════════════

model Document {
  id               String         @id @default(cuid())
  folio            String         @unique
  type             DocumentType
  status           DocumentStatus @default(DRAFT)
  companyId        String
  workArea         String
  taskName         String
  supervisorId     String?
  preventionistId  String?
  createdById      String
  scannedFileUrl       String?
  finalPdfUrl          String?
  qrCode               String?        @unique
  aiResult             Json?          // resultado bruto OCR/IA
  validationResult     Json?          // resultado motor de reglas
  // ── Geofence (circular) — opcional. Si no está configurado, GPS es evidencia
  // pero no bloquea. Ver src/modules/geofence para la lógica de validación.
  geofenceLat          Float?
  geofenceLng          Float?
  geofenceRadiusMeters Int?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  company       Company         @relation(fields: [companyId], references: [id])
  supervisor    User?           @relation("DocumentSupervisor", fields: [supervisorId], references: [id])
  preventionist User?           @relation("DocumentPreventionist", fields: [preventionistId], references: [id])
  createdBy     User            @relation("DocumentCreatedBy", fields: [createdById], references: [id])
  fields        DocumentField[]
  riskControls  RiskControl[]
  signatures    Signature[]
  approvals     Approval[]
  auditLogs     AuditLog[]
  notifications Notification[]
  jobs          Job[]

  @@index([companyId])
  @@index([status])
  @@index([type])
  @@index([createdAt])
  @@index([companyId, status])
  @@index([companyId, createdAt])
  @@map("documents")
}

// ═══════════════════════════════════════════════════════════════
// DOCUMENT FIELD
// confidence: 0.0–1.0 — confianza del OCR/IA al extraer el valor
// @@unique([documentId, fieldName]) — un campo por nombre por doc
// ═══════════════════════════════════════════════════════════════

model DocumentField {
  id         String   @id @default(cuid())
  documentId String
  fieldName  String
  fieldValue String?  @db.Text
  confidence Float?   // null si fue ingresado manualmente
  isRequired Boolean  @default(false)
  isValid    Boolean? // null = no validado, true = OK, false = error

  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, fieldName])
  @@index([documentId])
  @@map("document_fields")
}

// ═══════════════════════════════════════════════════════════════
// RISK CONTROL
// Pares riesgo/control identificados en el documento
// ═══════════════════════════════════════════════════════════════

model RiskControl {
  id          String      @id @default(cuid())
  documentId  String
  risk        String
  control     String
  criticality Criticality @default(MEDIUM)
  isValidated Boolean     @default(false)

  document    Document    @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@map("risk_controls")
}

// ═══════════════════════════════════════════════════════════════
// SIGNATURE
// @@unique([documentId, userId]) — un usuario firma una sola vez
// ═══════════════════════════════════════════════════════════════

model Signature {
  id                String         @id @default(cuid())
  documentId        String
  userId            String
  signatureImageUrl String
  method            SignatureMethod @default(DIGITAL)
  gpsLat            Float?
  gpsLng            Float?
  deviceInfo        Json?
  signedAt          DateTime       @default(now())

  document          Document       @relation(fields: [documentId], references: [id])
  user              User           @relation(fields: [userId], references: [id])

  @@unique([documentId, userId])
  @@index([documentId])
  @@map("signatures")
}

// ═══════════════════════════════════════════════════════════════
// APPROVAL
// role: captura el rol del aprobador EN EL MOMENTO de la decisión
// approvedAt: null si status = PENDING
// ═══════════════════════════════════════════════════════════════

model Approval {
  id         String         @id @default(cuid())
  documentId String
  approverId String
  role       UserRole
  status     ApprovalStatus @default(PENDING)
  comment    String?        @db.Text
  approvedAt DateTime?

  document   Document       @relation(fields: [documentId], references: [id])
  approver   User           @relation(fields: [approverId], references: [id])

  @@index([documentId])
  @@index([approverId, status])
  @@map("approvals")
}

// ═══════════════════════════════════════════════════════════════
// AUDIT LOG — INMUTABLE
// Nunca hacer UPDATE ni DELETE en esta tabla.
// Reforzar en PostgreSQL:
//   ALTER TABLE audit_logs ENABLE ROW LEVEL SECURITY;
//   CREATE POLICY no_update ON audit_logs FOR UPDATE USING (false);
//   CREATE POLICY no_delete ON audit_logs FOR DELETE USING (false);
// action: string libre para flexibilidad futura (ver lib/constants)
// ═══════════════════════════════════════════════════════════════

model AuditLog {
  id         String    @id @default(cuid())
  documentId String?
  userId     String
  action     String
  metadata   Json?
  ipAddress  String?
  deviceInfo Json?
  gpsLat     Float?
  gpsLng     Float?
  createdAt  DateTime  @default(now())

  document   Document? @relation(fields: [documentId], references: [id])
  user       User      @relation(fields: [userId], references: [id])

  @@index([documentId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ═══════════════════════════════════════════════════════════════
// NOTIFICATION
// message: contenido del mensaje (no en spec original, necesario)
// ═══════════════════════════════════════════════════════════════

model Notification {
  id          String              @id @default(cuid())
  documentId  String?
  recipientId String
  channel     NotificationChannel
  status      NotificationStatus  @default(PENDING)
  message     String?             @db.Text
  sentAt      DateTime?
  createdAt   DateTime            @default(now())

  document    Document?           @relation(fields: [documentId], references: [id])
  recipient   User                @relation(fields: [recipientId], references: [id])

  @@index([recipientId])
  @@index([status])
  @@map("notifications")
}

// ═══════════════════════════════════════════════════════════════
// JOB — cola persistente de trabajos async (OCR, PDF)
// Reemplaza InMemoryJobQueue — estado sobrevive reinicios
// ═══════════════════════════════════════════════════════════════

model Job {
  id          String    @id @default(cuid())
  type        JobType
  status      JobStatus @default(PENDING)
  documentId  String
  userId      String
  payload     Json      @default("{}")
  result      Json?
  error       String?
  attempts    Int       @default(0)
  createdAt   DateTime  @default(now())
  startedAt   DateTime?
  completedAt DateTime?

  document    Document  @relation(fields: [documentId], references: [id])
  user        User      @relation(fields: [userId], references: [id])

  @@index([documentId])
  @@index([userId])
  @@index([type, status])
  @@index([createdAt])
  @@map("jobs")
}
